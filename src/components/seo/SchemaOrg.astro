---
/**
 * @cw/core – SchemaOrg.astro
 *
 * Emits JSON-LD scripts into the `<head>`:
 *   1. LocalBusiness + ProfessionalService (+ optional additionalTypes)
 *   2. WebSite
 *   3. FAQPage (if `faqs` provided)
 *   4. Service (if `service` provided — for individual service pages)
 *
 * Prop-driven: no imports from customer data modules. Pass business data
 * from your site-data module (or wherever it lives).
 *
 * @example
 *   <SchemaOrg
 *     name={siteData.name}
 *     description={siteData.description}
 *     url={siteData.url}
 *     ogImage={siteData.seo.ogImage}
 *     street={siteData.legal.street}
 *     zip={siteData.legal.zip}
 *     city={siteData.legal.city}
 *     country={siteData.legal.country}
 *     email={siteData.contact.email}
 *     phone={siteData.contact.phone}
 *     additionalTypes={['RealEstateAgent']}
 *     employees={siteData.team}
 *     services={siteData.services}
 *     faqs={pageFaqs}
 *   />
 */
import type { WithContext, LocalBusiness, WebSite } from 'schema-dts';

export interface EmployeeData {
  name: string;
  role?: string;
  title?: string;
  phone?: string;
  email?: string;
  credentials?: string[] | readonly string[];
}

export interface ServiceData {
  label: string;
  shortDesc?: string;
  href: string;
}

export interface FaqData {
  question: string;
  answer: string;
}

interface Props {
  /** Business name. */
  name: string;
  /** Business description. */
  description: string;
  /** Canonical site URL (no trailing slash). */
  url: string;
  /** Path or absolute URL to OG image (resolved against `url`). */
  ogImage: string;
  /** Path or absolute URL to logo. Defaults to `${url}/logo.png`. */
  logoUrl?: string;
  /** Street address. */
  street?: string;
  /** Postal code. */
  zip?: string;
  /** City. */
  city?: string;
  /** ISO country code (e.g. "DE"). */
  country?: string;
  /** Contact email. */
  email?: string;
  /** Optional phone number. Emitted at LocalBusiness root AND in ContactPoint. */
  phone?: string;
  /**
   * Area served. Single city/region or array for multi-location coverage.
   * Emitted as schema.org `Place` objects so Google can map them to GEO entities.
   * Example: `['Regensburg', 'Barbing', 'Neutraubling']` or `'DE'`.
   */
  areaServed?: string | string[] | readonly string[];
  /** Schema.org `priceRange` hint. Defaults to "€€". */
  priceRange?: string;
  /** List of profile URLs (sameAs). Google Business Profile, Facebook, LinkedIn, etc. */
  sameAs?: string[] | readonly string[];
  /** Available languages for the contact point. Defaults to `['German']`. */
  availableLanguage?: string[] | readonly string[];
  /**
   * Opening hours in schema.org format.
   * Example: `['Mo-Fr 08:00-17:00', 'Sa 09:00-12:00']`.
   */
  openingHours?: string[] | readonly string[];
  /** Geographic coordinates for GEO ranking. */
  geo?: { latitude: number; longitude: number };
  /** Founding date (ISO 8601). */
  foundingDate?: string;

  // --- New props ---

  /**
   * Additional schema.org @type values merged into the LocalBusiness node.
   * Example: `['RealEstateAgent']` → `@type: ['LocalBusiness', 'ProfessionalService', 'RealEstateAgent']`
   */
  additionalTypes?: string[] | readonly string[];

  /**
   * Team members. Emitted as `employee` array with Person + credentials.
   * Each entry maps to a schema.org Person with EducationalOccupationalCredential.
   */
  employees?: EmployeeData[] | readonly EmployeeData[];

  /**
   * Business services. Emitted as `hasOfferCatalog` on the LocalBusiness node.
   * Also used for individual Service schemas on subpages (via `service` prop).
   */
  services?: ServiceData[] | readonly ServiceData[];

  /**
   * Single service for the current page (emits a standalone Service schema).
   * Pass the service object for the current Leistungsseite.
   */
  service?: ServiceData;

  /**
   * FAQ items for this page. Emits a FAQPage JSON-LD block.
   * Should also be rendered visibly on the page for AEO compliance.
   */
  faqs?: FaqData[] | readonly FaqData[];

  /**
   * Topics the business knows about. Emitted as `knowsAbout` on LocalBusiness.
   * Example: `['Immobilienbewertung', 'Verkehrswertgutachten']`
   */
  knowsAbout?: string[] | readonly string[];
}

const {
  name,
  description,
  url,
  ogImage,
  logoUrl,
  street,
  zip,
  city,
  country,
  email,
  phone,
  areaServed = 'DE',
  priceRange = '€€',
  sameAs = [],
  availableLanguage = ['German'],
  openingHours,
  geo,
  foundingDate,
  additionalTypes = [],
  employees,
  services,
  service,
  faqs,
  knowsAbout,
} = Astro.props;

// areaServed as Place[] is more precise than a raw string for multi-city GEO.
// Single string stays as-is (covers "DE" country-level and simple city cases).
const areaServedArr = Array.isArray(areaServed) ? areaServed : null;
const areaServedValue = areaServedArr
  ? areaServedArr.map((a) => ({ '@type': 'Place', name: a }))
  : areaServed;

const resolvedLogo = logoUrl ?? `${url}/logo.png`;
const resolvedImage = new URL(ogImage, url).toString();

// Build @type array: always LocalBusiness + ProfessionalService, plus any extras
const typeArray = ['LocalBusiness', 'ProfessionalService', ...(additionalTypes as string[])];

// schema-dts enforces a single `@type` literal per object; we emit an array
// because JSON-LD allows multiple types per node. Cast the composite object.
const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': typeArray,
  name,
  description,
  url,
  logo: resolvedLogo,
  image: resolvedImage,
  ...(phone ? { telephone: phone } : {}),
  ...(street || zip || city || country
    ? {
        address: {
          '@type': 'PostalAddress',
          ...(street ? { streetAddress: street } : {}),
          ...(zip ? { postalCode: zip } : {}),
          ...(city ? { addressLocality: city } : {}),
          ...(country ? { addressCountry: country } : {}),
        },
      }
    : {}),
  ...(geo
    ? {
        geo: {
          '@type': 'GeoCoordinates',
          latitude: geo.latitude,
          longitude: geo.longitude,
        },
      }
    : {}),
  ...(openingHours && openingHours.length
    ? { openingHours: [...openingHours] }
    : {}),
  ...(foundingDate ? { foundingDate } : {}),
  ...(email
    ? {
        contactPoint: {
          '@type': 'ContactPoint',
          contactType: 'customer service',
          email,
          ...(phone ? { telephone: phone } : {}),
          availableLanguage,
        },
      }
    : {}),
  areaServed: areaServedValue,
  priceRange,
  sameAs: [...sameAs],
  // --- New fields ---
  ...(employees && employees.length
    ? {
        employee: [...employees].map((m) => ({
          '@type': 'Person',
          name: m.name,
          ...(m.role ? { jobTitle: m.role } : {}),
          ...(m.title ? { honorificSuffix: m.title } : {}),
          ...(m.phone ? { telephone: m.phone } : {}),
          ...(m.email ? { email: m.email } : {}),
          worksFor: { '@type': 'Organization', name },
          ...(m.credentials && m.credentials.length
            ? {
                hasCredential: [...m.credentials].map((c) => ({
                  '@type': 'EducationalOccupationalCredential',
                  credentialCategory: 'certification',
                  name: c,
                })),
              }
            : {}),
        })),
      }
    : {}),
  ...(services && services.length
    ? {
        hasOfferCatalog: {
          '@type': 'OfferCatalog',
          name: 'Leistungen',
          itemListElement: [...services].map((s, i) => ({
            '@type': 'Offer',
            itemOffered: {
              '@type': 'Service',
              name: s.label,
              ...(s.shortDesc ? { description: s.shortDesc } : {}),
              url: `${url}${s.href}`,
            },
            position: i + 1,
          })),
        },
      }
    : {}),
  ...(knowsAbout && knowsAbout.length ? { knowsAbout: [...knowsAbout] } : {}),
} as unknown as WithContext<LocalBusiness>;

const webSiteSchema: WithContext<WebSite> = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name,
  description,
  url,
};

// FAQPage schema (standalone block)
const faqSchema = faqs && faqs.length > 0
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: [...faqs].map((faq) => ({
        '@type': 'Question',
        name: faq.question,
        acceptedAnswer: {
          '@type': 'Answer',
          text: faq.answer,
        },
      })),
    }
  : null;

// Standalone Service schema (for individual Leistungsseiten)
const serviceSchema = service
  ? {
      '@context': 'https://schema.org',
      '@type': 'Service',
      name: service.label,
      ...(service.shortDesc ? { description: service.shortDesc } : {}),
      url: `${url}${service.href}`,
      provider: {
        '@type': typeArray,
        name,
        url,
      },
      areaServed: areaServedValue,
    }
  : null;
---
<script is:inline type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
<script is:inline type="application/ld+json" set:html={JSON.stringify(webSiteSchema)} />
{faqSchema && <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
{serviceSchema && <script is:inline type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />}
