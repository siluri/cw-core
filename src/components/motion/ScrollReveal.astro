---
/**
 * @cw/core – motion/ScrollReveal.astro
 *
 * Wrapper that fades/slides its slot into view the first time it
 * intersects the viewport. CSS-only: no library required, respects
 * `prefers-reduced-motion` via tokens-base.css.
 *
 * @example
 *   <ScrollReveal direction="up" delay={0.1}>
 *     <h2>Headline</h2>
 *   </ScrollReveal>
 */
export type RevealDirection = 'up' | 'down' | 'left' | 'right' | 'zoom' | 'fade';

interface Props {
  /** Entry direction. Defaults to "up". "fade" = opacity only. */
  direction?: RevealDirection;
  /** Delay in seconds before animating. Defaults to 0. */
  delay?: number;
  /** Animation duration override (CSS time, e.g. "0.8s"). */
  duration?: string;
  /** Viewport threshold 0-1. Defaults to 0.15. */
  threshold?: number;
  /** Additional class names on the wrapper. */
  class?: string;
  /** HTML element tag. Defaults to "div". */
  as?: string;
}

const {
  direction = 'up',
  delay = 0,
  duration,
  threshold = 0.15,
  class: className = '',
  as: Tag = 'div',
} = Astro.props;

const revealAttr = direction === 'fade' ? '' : direction;
const style = [
  delay ? `transition-delay: ${delay}s` : '',
  duration ? `transition-duration: ${duration}` : '',
].filter(Boolean).join('; ');
---
<Tag
  data-motion-reveal={revealAttr}
  data-motion-threshold={threshold}
  class={className}
  style={style || undefined}
>
  <slot />
</Tag>

<script>
  // Runs once per page. Observes every [data-motion-reveal] element and
  // toggles `.is-visible` on entry. No library dependency.
  const init = () => {
    const els = document.querySelectorAll<HTMLElement>('[data-motion-reveal]:not(.is-visible)');
    if (!els.length) return;
    if (!('IntersectionObserver' in window)) {
      els.forEach((el) => el.classList.add('is-visible'));
      return;
    }
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            io.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15, rootMargin: '0px 0px -10% 0px' },
    );
    els.forEach((el) => io.observe(el));
  };
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
  document.addEventListener('astro:page-load', init);
</script>
