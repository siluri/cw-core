---
/**
 * @cw/core – blocks/BentoGrid.astro
 *
 * Asymmetric CSS-grid for feature tiles with optional column/row
 * spanning. Prop-driven, zero runtime — pure layout primitive.
 *
 * Layout dramaturgy (critical for impact):
 *   1 dominant tile (span 2×2) + 2 semi-dominant (1×1 rich content)
 *   + rest support. Without hard information hierarchy a bento grid
 *   is just a Dribbble façade — plan content first, span second.
 *
 * Items with `href` render as `<a>` (accessible clickable card),
 * others as `<article>`. Responsive: below 768px all spans collapse
 * to a single column.
 *
 * @example
 *   <BentoGrid
 *     heading="Warum Blitzsicht"
 *     columns={4}
 *     items={[
 *       { title: 'Fertig in 7 Werktagen', icon: '⚡', accent: true, span: { cols: 2, rows: 2 } },
 *       { title: 'Ohne Cookie-Banner', icon: '🍪', description: 'Plausible Analytics.' },
 *       { title: 'Kein Vendor-Lock-in', icon: '🔓', description: 'Source-Code in deinem Besitz.' },
 *       { title: 'Feste Pakete', icon: '📦' },
 *       { title: 'Echte Ansprechpartner', icon: '👤' },
 *       { title: 'DSGVO-konforme Formulare', icon: '✉️' },
 *     ]}
 *   />
 */
export interface BentoItem {
  /** Main heading of the tile. */
  title: string;
  /** Small label above the title (e.g. "TRUST"). */
  eyebrow?: string;
  /** Body copy. Optional. */
  description?: string;
  /** Emoji or single-character glyph. */
  icon?: string;
  /** If set, tile renders as `<a>`. */
  href?: string;
  /** Link target (for `href`). */
  target?: '_blank' | '_self';
  /** Link rel (e.g. 'noopener noreferrer'). */
  rel?: string;
  /** Column/row spanning. `cols: 2` or `rows: 2` create a larger tile. */
  span?: { cols?: 1 | 2; rows?: 1 | 2 };
  /** Paint with accent background + foreground. */
  accent?: boolean;
  /** Optional accessible label (for icon-only tiles or combined content). */
  ariaLabel?: string;
}

interface Props {
  items: readonly BentoItem[];
  /** Number of columns on desktop. Default 3. */
  columns?: number;
  /** Gap between tiles (any CSS length). Default '1rem'. */
  gap?: string;
  /** Optional section heading. */
  heading?: string;
  /** Optional section subheading. */
  subheading?: string;
}

const {
  items,
  columns = 3,
  gap = '1rem',
  heading,
  subheading,
} = Astro.props;

const spanStyle = (span?: BentoItem['span']) => {
  if (!span) return undefined;
  const parts: string[] = [];
  if (span.cols === 2) parts.push('grid-column: span 2');
  if (span.rows === 2) parts.push('grid-row: span 2');
  return parts.length ? parts.join(';') : undefined;
};
---
<section class="bento">
  <div class="container">
    {heading && <h2 class="bento-heading">{heading}</h2>}
    {subheading && <p class="bento-sub">{subheading}</p>}
    <div class="bento-grid" style={`--bento-cols:${columns};--bento-gap:${gap};`}>
      {items.map((item) => {
        const classes = [
          'bento-item',
          item.accent && 'bento-item--accent',
          item.href && 'bento-item--link',
        ];
        const style = spanStyle(item.span);
        if (item.href) {
          return (
            <a
              href={item.href}
              target={item.target}
              rel={item.rel}
              aria-label={item.ariaLabel}
              class:list={classes}
              style={style}
            >
              {item.eyebrow && <span class="bento-eyebrow">{item.eyebrow}</span>}
              {item.icon && <span class="bento-icon" aria-hidden="true">{item.icon}</span>}
              <h3>{item.title}</h3>
              {item.description && <p>{item.description}</p>}
            </a>
          );
        }
        return (
          <article
            aria-label={item.ariaLabel}
            class:list={classes}
            style={style}
          >
            {item.eyebrow && <span class="bento-eyebrow">{item.eyebrow}</span>}
            {item.icon && <span class="bento-icon" aria-hidden="true">{item.icon}</span>}
            <h3>{item.title}</h3>
            {item.description && <p>{item.description}</p>}
          </article>
        );
      })}
    </div>
  </div>
</section>

<style>
  .bento { padding: 5rem 0; }
  .bento-heading {
    text-align: center;
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    margin: 0 0 0.75rem;
  }
  .bento-sub {
    text-align: center;
    color: var(--color-muted, rgba(0, 0, 0, 0.6));
    margin: 0 0 2.5rem;
  }

  .bento-grid {
    display: grid;
    grid-template-columns: repeat(var(--bento-cols), 1fr);
    gap: var(--bento-gap);
    grid-auto-flow: dense;
    max-width: 72rem;
    margin-inline: auto;
  }

  .bento-item {
    padding: 1.75rem;
    border-radius: 1rem;
    background: var(--color-bg-surface, #fff);
    border: 1px solid var(--color-border, #e5e7eb);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
    transition: transform 0.2s, box-shadow 0.2s;
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .bento-item:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.08);
  }
  .bento-item--link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 3px;
  }

  .bento-eyebrow {
    display: block;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted, rgba(0, 0, 0, 0.55));
    margin-bottom: 0.5rem;
  }
  .bento-icon {
    font-size: 2rem;
    line-height: 1;
    margin-bottom: 0.75rem;
    display: block;
  }
  .bento-item h3 {
    margin: 0 0 0.5rem;
    font-size: 1.125rem;
    line-height: 1.3;
  }
  .bento-item p {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--color-muted, rgba(0, 0, 0, 0.7));
  }

  .bento-item--accent {
    background: var(--color-accent);
    color: var(--color-accent-foreground, #fff);
    border-color: transparent;
  }
  .bento-item--accent .bento-eyebrow,
  .bento-item--accent p {
    color: var(--color-accent-foreground, #fff);
    opacity: 0.9;
  }

  /* stylelint-disable-next-line plugin/no-max-width-media -- Legacy Desktop-First, TODO: refactor to Mobile-First */
  @media (max-width: 768px) {
    .bento-grid { grid-template-columns: 1fr; }
    .bento-item {
      grid-column: auto !important;
      grid-row: auto !important;
    }
  }
</style>
