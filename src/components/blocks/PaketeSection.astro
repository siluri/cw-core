---
/**
 * @cw/core – PaketeSection.astro
 *
 * Pricing/packages section. Prop-driven: no `@/data/site-data` import.
 *
 * Layout pattern (from Blitzsicht-Audit):
 * - 3-column grid; middle card with shadow-xl + negative margin
 * - Badge absolutely positioned as pill above the card
 * - Inline SVG checkmarks (no icon library import)
 * - CTA as pill (border-radius: 100px)
 * - Price display: 2.25rem bold
 *
 * @example
 *   <PaketeSection items={siteData.packages} tilt={true} />
 */
import TiltCard from '../motion/TiltCard.astro';

export interface PaketeItem {
  /** Package name (large heading). */
  name: string;
  /** Subtitle / eyebrow. */
  subtitle: string;
  /** One-time setup price (number, formatted with de-DE locale). */
  priceSetup: number;
  /** Monthly recurring price (number). */
  priceMonthly: number;
  /** Optional pages/scope hint (rendered as small pill). */
  pages?: string;
  /** Bullet feature list. */
  features: readonly string[];
  /** If true, the card is highlighted (accent border, shadow, "Meistgewählt" badge). */
  highlighted?: boolean;
  /** CTA href; defaults to `/kontakt`. */
  ctaHref?: string;
  /** CTA label; defaults to `${name} anfragen`. */
  ctaLabel?: string;
}

interface Props {
  /** Package cards. */
  items?: readonly PaketeItem[];
  /** Whether to render the section header. */
  showTitle?: boolean;
  /** Optional override for the section heading. */
  heading?: string;
  /** Optional override for the section subheading. */
  subheading?: string;
  /** Footnote rendered below the grid. */
  note?: string;
  /** Wrap each card in a `<TiltCard>` for 3D hover-tilt. Default true (opt-out with `tilt={false}`). */
  tilt?: boolean;
  /** Single-card mode: centers the card, removes highlight negative margins. Use when showing only the highlighted package on a landing page. */
  single?: boolean;
}

const {
  items = [],
  showTitle = true,
  heading = 'Transparente Preise. Keine Überraschungen.',
  subheading = 'Einmalige Einrichtung + monatliche Betreuung. Alle Preise netto zzgl. 19\u00a0% MwSt.',
  note = 'Alle Pakete: Source-Code gehört Ihnen · Hosting + Domain inklusive · DSGVO-konform ohne Cookie-Banner',
  tilt = true,
  single = false,
} = Astro.props;
---
<section class="pakete-section">
  <div class="container">
    {showTitle && (
      <div class="section-header">
        <h2 class="section-heading">{heading}</h2>
        <p class="section-subheading" set:html={subheading} />
      </div>
    )}

    <div class:list={['pakete-grid', single && 'pakete-grid--single']}>
      {items.map((pkg) => {
        const card = (
          <div class:list={['paket-card', pkg.highlighted && 'highlighted']}>
            {pkg.highlighted && <span class="highlight-badge">Meistgewählt</span>}
            <p class="paket-eyebrow">{pkg.subtitle}</p>
            <h3 class="paket-name">{pkg.name}</h3>

            <div class="paket-pricing">
              {pkg.priceSetup > 0 ? (
                <>
                  <span class="price-amount">{pkg.priceSetup.toLocaleString('de-DE')}&thinsp;€</span>
                  <span class="price-label">einmalig</span>
                </>
              ) : (
                <span class="price-amount price-anfrage">Auf Anfrage</span>
              )}
            </div>
            {pkg.priceMonthly > 0 && (
              <div class="paket-pricing-monthly">
                <span>danach</span>
                <strong>{pkg.priceMonthly}&thinsp;€</strong>
                <span>/ Monat</span>
              </div>
            )}

            {pkg.pages && <p class="paket-pages">{pkg.pages}</p>}

            <ul class="feature-list">
              {pkg.features.map((f) => (
                <li>
                  <svg class="check-icon" width="20" height="20" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 111.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                  {f}
                </li>
              ))}
            </ul>

            <a
              href={pkg.ctaHref ?? '/kontakt'}
              class:list={['paket-cta', pkg.highlighted ? 'cta-primary' : 'cta-outline']}
            >
              {pkg.ctaLabel ?? `${pkg.name} anfragen`}
            </a>
          </div>
        );
        return tilt ? <TiltCard>{card}</TiltCard> : card;
      })}
    </div>

    {note && <p class="pakete-note">{note}</p>}
  </div>
</section>

<script>
  import { track } from '../../utils/analytics/track';
  document.querySelectorAll<HTMLAnchorElement>('.paket-cta').forEach((link) => {
    link.addEventListener('click', () => {
      const name = link.closest('.paket-card')?.querySelector('.paket-name')?.textContent?.trim() ?? '';
      track('Package Click', { package_name: name });
    });
  });
</script>

<style>
  .pakete-section { padding: 5rem 0; background: var(--color-surface); }
  .section-header { text-align: center; margin-bottom: 3.5rem; }

  .pakete-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    align-items: start;
    max-width: 72rem;
    margin-inline: auto;
  }
  .paket-card {
    position: relative;
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 1rem;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    height: 100%;
  }
  .paket-card.highlighted {
    border-color: var(--color-accent);
    box-shadow: 0 20px 48px -12px rgba(0, 0, 0, 0.15);
    margin-top: -1rem;
    margin-bottom: -1rem;
    padding: 2.5rem 2rem;
    z-index: 1;
  }
  .highlight-badge {
    position: absolute;
    top: -0.75rem;
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-primary);
    color: white;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.25rem 1rem;
    border-radius: 100px;
    white-space: nowrap;
  }
  .paket-eyebrow {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-muted);
    margin: 0 0 0.5rem;
  }
  .paket-name { font-size: 1.75rem; font-weight: 700; margin: 0 0 1rem; }
  .paket-pricing {
    display: flex;
    align-items: baseline;
    gap: 0.375rem;
    margin-bottom: 0.25rem;
  }
  .price-amount { font-size: 2.25rem; font-weight: 700; color: var(--color-primary); line-height: 1; }
  .price-anfrage { font-size: 1.5rem; }
  .price-label { font-size: 0.875rem; color: var(--color-muted); }
  .paket-pricing-monthly {
    font-size: 0.875rem;
    color: var(--color-muted);
    margin-bottom: 1rem;
    display: flex;
    align-items: baseline;
    gap: 0.25rem;
  }
  .paket-pricing-monthly strong { color: var(--color-primary); font-size: 1rem; }
  .paket-pages {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    background: var(--color-surface);
    padding: 0.25rem 0.75rem;
    border-radius: 100px;
    color: var(--color-primary);
    margin: 0 0 1.5rem;
    align-self: flex-start;
  }
  .paket-card.highlighted .paket-pages {
    background: rgba(239, 118, 18, 0.08);
    color: var(--color-accent-text, #B85A0D);
  }
  .feature-list {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex: 1;
  }
  .feature-list li { display: flex; align-items: flex-start; gap: 0.5rem; font-size: 0.875rem; line-height: 1.5; }
  .check-icon { flex-shrink: 0; margin-top: 1px; color: var(--color-accent); }
  .paket-cta {
    display: block;
    text-align: center;
    padding: 0.875rem 1.5rem;
    border-radius: 100px;
    font-weight: 700;
    font-size: 0.9375rem;
    text-decoration: none;
    min-height: 48px;
    transition: background 0.2s, border-color 0.2s, transform 0.1s;
  }
  .cta-primary { background: var(--color-accent); color: white; }
  .cta-primary:hover { background: var(--color-accent-hover); transform: translateY(-1px); }
  .cta-outline { background: transparent; color: var(--color-primary); border: 2px solid #e5e7eb; }
  .cta-outline:hover { border-color: var(--color-primary); background: var(--color-surface); }
  .pakete-note { text-align: center; margin-top: 2rem; font-size: 0.8125rem; color: var(--color-muted); }

  .pakete-grid--single {
    grid-template-columns: 1fr;
    max-width: 460px;
    margin-inline: auto;
  }
  .pakete-grid--single .paket-card.highlighted {
    margin-top: 0;
    margin-bottom: 0;
  }

  @media (max-width: 900px) {
    .pakete-grid { grid-template-columns: 1fr; max-width: 480px; margin-inline: auto; }
    .paket-card.highlighted { margin-top: 0; margin-bottom: 0; }
  }
</style>
