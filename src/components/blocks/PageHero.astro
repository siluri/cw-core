---
/**
 * PageHero — gradient banner for sub-pages (not the main Hero).
 *
 * Renders a dark gradient section with heading + optional subtext.
 * Uses `--color-primary` as gradient start and auto-darkens via `color-mix`.
 * Override `--color-primary-dark` in tokens.css for fine control.
 *
 * Used on: /pakete, /kontakt, /faq, /leistungen, /ueber-uns, /referenzen, etc.
 */
interface Props {
  heading: string;
  subtext?: string;
}

const { heading, subtext } = Astro.props;
---
<section class="page-hero">
  <div class="container">
    <h1>{heading}</h1>
    {subtext && <p>{subtext}</p>}
  </div>
</section>

<style>
  .page-hero {
    background: linear-gradient(
      135deg,
      var(--color-primary) 0%,
      var(--color-primary-dark, color-mix(in srgb, var(--color-primary), black 25%)) 100%
    );
    color: white;
    padding: 4rem 0 3rem;
  }
  .page-hero h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    color: white;
    margin-bottom: 0.75rem;
  }
  .page-hero p {
    color: rgba(255, 255, 255, 0.8);
    font-size: 1.0625rem;
    max-width: 44rem;
  }
</style>
