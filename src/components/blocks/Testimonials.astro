---
/**
 * @cw/core – Testimonials.astro
 *
 * Customer testimonial grid with Schema.org Review markup. Prop-driven:
 * no `@/data/site-data` import.
 *
 * @example
 *   <Testimonials items={siteData.testimonials} siteName={siteData.name} />
 *
 * Tilt caveat: on text-heavy testimonials, 3D tilt reduces readability.
 * Default `tilt={false}`; only enable after visual check, and consider
 * passing a smaller `maxTilt` to `<TiltCard>` via a custom wrapper.
 */
import TiltCard from '../motion/TiltCard.astro';

export interface Testimonial {
  /** Star rating (1-5). */
  stars: number;
  /** Review body / quote. */
  text: string;
  /** Reviewer name. */
  name: string;
  /** Reviewer role/company. */
  role: string;
}

interface Props {
  /** Testimonial entries. Section is omitted if empty. */
  items?: readonly Testimonial[];
  /** Site name used in itemprop="name" for the reviewed Product. */
  siteName?: string;
  /** Optional override for the section heading. */
  heading?: string;
  /** Optional override for the section subheading. */
  subheading?: string;
  /** Optional override for the Product itemprop name (defaults to `${siteName} Website-Service`). */
  productName?: string;
  /** Wrap each testimonial in `<TiltCard>` (default false — text-heavy content suffers from tilt). */
  tilt?: boolean;
}

const {
  items = [],
  siteName = '',
  heading = 'Das sagen unsere Kunden',
  subheading = 'Bewertungen von Unternehmen aus der Region.',
  productName,
  tilt = false,
} = Astro.props;

const itempropName = productName ?? `${siteName} Website-Service`;
---
{items.length > 0 && (
<section class="testimonials-section" itemscope itemtype="https://schema.org/Product">
  <meta itemprop="name" content={itempropName} />
  <div class="container">
    <div class="section-header">
      <h2 class="section-heading">{heading}</h2>
      <p class="section-subheading">{subheading}</p>
    </div>

    <div class="testimonials-grid">
      {items.map((t) => {
        const card = (
          <div class="testimonial-card" itemprop="review" itemscope itemtype="https://schema.org/Review">
            <div class="stars" itemprop="reviewRating" itemscope itemtype="https://schema.org/Rating">
              <meta itemprop="ratingValue" content={String(t.stars)} />
              <meta itemprop="bestRating" content="5" />
              {'★'.repeat(t.stars)}
            </div>
            <blockquote itemprop="reviewBody">{t.text}</blockquote>
            <div class="author" itemprop="author" itemscope itemtype="https://schema.org/Person">
              <strong itemprop="name">{t.name}</strong>
              <span>{t.role}</span>
            </div>
          </div>
        );
        return tilt ? <TiltCard>{card}</TiltCard> : card;
      })}
    </div>
  </div>
</section>
)}

<style>
  .testimonials-section { padding: 5rem 0; background: var(--color-surface); }
  .section-header { text-align: center; margin-bottom: 3rem; }
  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    max-width: 64rem;
    margin-inline: auto;
  }
  .testimonial-card {
    background: white;
    border-radius: 0.75rem;
    padding: 2rem;
    border: 1px solid #e5e7eb;
  }
  .stars {
    color: var(--color-accent);
    font-size: 1.25rem;
    margin-bottom: 1rem;
    letter-spacing: 2px;
  }
  blockquote {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--color-primary);
    margin: 0 0 1.25rem;
    font-style: normal;
  }
  .author strong { display: block; font-size: 0.9375rem; }
  .author span { font-size: 0.8125rem; color: var(--color-muted); }
  @media (max-width: 768px) {
    .testimonials-grid { grid-template-columns: 1fr; gap: 1.25rem; }
  }
</style>
