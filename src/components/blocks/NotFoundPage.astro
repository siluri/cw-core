---
/**
 * NotFoundPage — 404 content block.
 *
 * Renders a centered 404 message with back-to-home CTA.
 * Wrap in LandingPage (with header/footer) or BaseLayout.
 */
interface Props {
  heading?: string;
  subtext?: string;
  ctaLabel?: string;
  ctaHref?: string;
}

const {
  heading = 'Seite nicht gefunden',
  subtext = 'Diese Seite existiert nicht oder wurde verschoben.',
  ctaLabel = 'Zur Startseite',
  ctaHref = '/',
} = Astro.props;
---
<main class="not-found">
  <h1 class="not-found-code">404</h1>
  <h2 class="not-found-heading">{heading}</h2>
  <p class="not-found-text">{subtext}</p>
  <a href={ctaHref} class="not-found-cta">{ctaLabel}</a>
</main>

<style>
  .not-found {
    max-width: var(--container-max, 72rem);
    margin: 0 auto;
    padding: 8rem 1rem;
    text-align: center;
  }
  .not-found-code {
    font-size: 3.75rem;
    font-weight: 700;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }
  .not-found-heading {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 1rem;
  }
  .not-found-text {
    color: var(--color-muted, #6b7280);
    margin-bottom: 2rem;
  }
  .not-found-cta {
    display: inline-block;
    background: var(--color-accent);
    color: var(--color-accent-btn-text, white);
    font-weight: 500;
    padding: 0.75rem 1.5rem;
    border-radius: 0.5rem;
    text-decoration: none;
    transition: background 0.2s;
  }
  .not-found-cta:hover {
    background: var(--color-accent-hover, var(--color-accent));
  }
</style>

<script>
  import { track } from '@/utils/analytics/track';
  track('404 Error', { path: window.location.pathname });
</script>
