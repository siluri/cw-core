---
/**
 * @cw/core – CTABlock.astro
 *
 * Full-width call-to-action section with primary + secondary button.
 * Fully prop-driven; no imports from customer data modules.
 *
 * @example
 *   <CTABlock
 *     headline="Bereit für Ihre neue Website?"
 *     sub="Kostenloses Erstgespräch — 30 Minuten, unverbindlich."
 *     primaryLabel="Beratung anfragen"
 *     primaryHref="/kontakt"
 *     secondaryLabel="Pakete & Preise"
 *     secondaryHref="/pakete"
 *   />
 */
interface Props {
  /** Main heading of the CTA block. */
  headline?: string;
  /** Supporting copy under the heading. */
  sub?: string;
  /** Primary button label. */
  primaryLabel?: string;
  /** Primary button href. */
  primaryHref?: string;
  /** Secondary (outline) button label. Hidden if empty. */
  secondaryLabel?: string;
  /** Secondary button href. */
  secondaryHref?: string;
}
const {
  headline = 'Bereit für Ihre neue Website?',
  sub = 'Kostenloses Erstgespräch – 30 Minuten, unverbindlich, kein Verkaufsdruck.',
  primaryLabel = 'Beratung anfragen',
  primaryHref = '/kontakt',
  secondaryLabel = 'Pakete & Preise ansehen',
  secondaryHref = '/pakete',
} = Astro.props;
---
<section class="cta-section">
  <div class="container">
    <div class="cta-inner">
      <div class="cta-bolt" aria-hidden="true">
        <svg width="48" height="48" viewBox="0 0 512 512">
          <polygon points="296,80 176,288 248,288 216,432 336,224 264,224" fill="white" opacity="0.3"/>
        </svg>
      </div>
      <h2>{headline}</h2>
      <p>{sub}</p>
      <div class="cta-buttons">
        <a href={primaryHref} class="btn-accent" data-track-cta={primaryLabel}>{primaryLabel}</a>
        {secondaryLabel && <a href={secondaryHref} class="btn-outline" data-track-cta={secondaryLabel}>{secondaryLabel}</a>}
      </div>
    </div>
  </div>
</section>

<script>
  import { track } from '@/utils/analytics/track';
  document.querySelectorAll<HTMLAnchorElement>('[data-track-cta]').forEach((link) => {
    link.addEventListener('click', () => {
      track('CTA Click', { label: link.dataset.trackCta ?? '' });
    });
  });
</script>

<style>
  .cta-section {
    padding: 5rem 0;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark, #0f3460) 100%);
    color: white;
  }
  .cta-inner { text-align: center; max-width: 42rem; margin-inline: auto; position: relative; }
  .cta-bolt { position: absolute; top: -2rem; left: 50%; transform: translateX(-50%); opacity: 0.4; }
  .cta-inner h2 { font-size: clamp(1.75rem, 3vw, 2.5rem); color: white; margin-bottom: 1rem; }
  .cta-inner p { font-size: 1.0625rem; color: rgba(255,255,255,0.8); line-height: 1.7; margin-bottom: 2rem; }
  .cta-buttons { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
</style>
