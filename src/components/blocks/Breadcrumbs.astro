---
/**
 * @cw/core – Breadcrumbs.astro
 *
 * Renders a visible breadcrumb <nav> AND a matching JSON-LD BreadcrumbList
 * for Google rich results. Use on detail pages, service pages, blog posts.
 *
 * Current item should have no `href` (renders as plain text + aria-current).
 *
 * @example
 *   <Breadcrumbs
 *     items={[
 *       { label: 'Start', href: '/' },
 *       { label: 'Leistungen', href: '/leistungen' },
 *       { label: 'Komplettsanierung' },
 *     ]}
 *     siteUrl="https://steller-sanierungen.com"
 *   />
 */
interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  /** Breadcrumb trail. Last item should have no href (current page). */
  items: BreadcrumbItem[];
  /** Canonical site URL (no trailing slash). Used to resolve href→absolute for JSON-LD. */
  siteUrl: string;
}

const { items, siteUrl } = Astro.props;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: items.map((item, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: item.label,
    ...(item.href ? { item: new URL(item.href, siteUrl).toString() } : {}),
  })),
};
---
<nav class="breadcrumbs" aria-label="Breadcrumb">
  <ol>
    {items.map((item, i) => (
      <li>
        {item.href ? (
          <a href={item.href}>{item.label}</a>
        ) : (
          <span aria-current="page">{item.label}</span>
        )}
        {i < items.length - 1 && <span class="sep" aria-hidden="true">›</span>}
      </li>
    ))}
  </ol>
</nav>
<script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

<style>
  .breadcrumbs {
    font-size: 0.875rem;
    color: var(--color-muted, #6b7280);
    padding: 1rem 0;
  }
  .breadcrumbs ol {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    align-items: center;
  }
  .breadcrumbs li {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
  }
  .breadcrumbs a {
    color: inherit;
    text-decoration: none;
    transition: color 0.15s;
  }
  .breadcrumbs a:hover {
    color: var(--color-primary, #1f2937);
    text-decoration: underline;
  }
  .breadcrumbs [aria-current='page'] {
    color: var(--color-text, #1f2937);
    font-weight: 500;
  }
  .breadcrumbs .sep {
    opacity: 0.5;
  }
</style>
