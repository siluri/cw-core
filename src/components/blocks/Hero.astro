---
/**
 * @cw/core – Hero.astro
 *
 * Reusable hero section with two layout variants:
 *   • `image` prop set  → Split-Layout (Text 55%, Image 45%)
 *   • `image` not set   → Gradient-Only (Text left-aligned, full-width)
 *
 * Prop-driven: no imports from customer data modules. The consuming page
 * (or a higher-level page component) is responsible for passing site data
 * from `@/data/site-data` (or equivalent) via props.
 *
 * @example
 *   <Hero
 *     badge="Fertig in 7 Tagen"
 *     headline="Professionelle Website.<br/>Ohne Warteliste."
 *     subtext="…"
 *     ctaPrimary={{ label: 'Beratung anfragen', href: '/kontakt' }}
 *     ctaSecondary={{ label: 'Audit', href: '/website-audit' }}
 *     usps={siteData.usps}
 *     siteName={siteData.name}
 *   />
 */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

export interface HeroCTA {
  label: string;
  href: string;
}

export interface HeroUSP {
  icon: string;
  title: string;
}

interface Props {
  /** Small badge above the headline. Defaults to "Fertig in 7 Tagen – garantiert". */
  badge?: string;
  /** Main headline. Supports HTML (e.g. `<br/>`) via set:html. */
  headline: string;
  /** Sub-copy under the headline. */
  subtext?: string;
  /** Optional hero image. If set, triggers split layout. Accepts Astro ImageMetadata or URL string. */
  image?: ImageMetadata | string;
  /** Alt text for the hero image. Falls back to `siteName`. */
  imageAlt?: string;
  /** Site name used as image alt fallback. */
  siteName?: string;
  /** Primary CTA (accent button). */
  ctaPrimary?: HeroCTA;
  /** Optional secondary CTA (outline button). */
  ctaSecondary?: HeroCTA;
  /** Optional USP chips shown below the CTAs. */
  usps?: readonly HeroUSP[];
}

const {
  badge = 'Fertig in 7 Tagen – garantiert',
  headline,
  subtext,
  image,
  imageAlt,
  siteName,
  ctaPrimary = { label: 'Kostenlose Beratung anfragen', href: '/kontakt' },
  ctaSecondary,
  usps = [],
} = Astro.props;

const hasImage = !!image;
---
<section class:list={['hero', hasImage && 'hero--split']}>
  <div class="container">
    <div class="hero-content">
      <div class="hero-badge">
        <svg width="14" height="14" viewBox="0 0 512 512" aria-hidden="true">
          <polygon points="296,80 176,288 248,288 216,432 336,224 264,224" fill="currentColor"/>
        </svg>
        {badge}
      </div>

      <h1 set:html={headline} />

      {subtext && <p class="hero-sub">{subtext}</p>}

      <div class="hero-cta">
        <a href={ctaPrimary.href} class="btn-accent">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
          {ctaPrimary.label}
        </a>
        {ctaSecondary && (
          <a href={ctaSecondary.href} class="btn-outline">
            {ctaSecondary.label}
          </a>
        )}
      </div>

      {usps.length > 0 && (
        <div class="hero-usps">
          {usps.map((usp) => (
            <div class="hero-usp-item">
              <span class="usp-icon" aria-hidden="true">{usp.icon}</span>
              <span>{usp.title}</span>
            </div>
          ))}
        </div>
      )}
    </div>

    {hasImage && typeof image !== 'string' && (
      <div class="hero-image-wrap">
        <Image
          src={image!}
          alt={imageAlt ?? siteName ?? ''}
          widths={[400, 600, 800]}
          sizes="(max-width: 767px) 100vw, 45vw"
          loading="eager"
          fetchpriority="high"
          format="webp"
          class="hero-img"
        />
      </div>
    )}
    {hasImage && typeof image === 'string' && (
      <div class="hero-image-wrap">
        <img
          src={image}
          alt={imageAlt ?? siteName ?? ''}
          width={600}
          height={450}
          loading="eager"
          fetchpriority="high"
          class="hero-img"
        />
      </div>
    )}
  </div>
</section>

<style>
  .hero {
    background: linear-gradient(135deg, var(--color-primary) 0%, #0f3460 100%);
    color: white;
    padding: 5rem 0 4rem;
  }

  /* Split-Layout (mit Bild) */
  .hero--split .container {
    display: grid;
    grid-template-columns: 55fr 45fr;
    gap: 3rem;
    align-items: center;
  }
  .hero-image-wrap {
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: 0 24px 64px rgba(0,0,0,0.35);
  }
  .hero-img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  /* Gemeinsame Styles */
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(255,107,53,0.2);
    color: var(--color-accent);
    border: 1px solid rgba(255,107,53,0.4);
    border-radius: 100px;
    padding: 0.375rem 0.875rem;
    font-size: 0.8125rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
    letter-spacing: 0.02em;
  }
  h1 {
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    color: white;
    margin: 0 0 1.25rem;
    max-width: 18ch;
  }
  .hero-sub {
    font-size: clamp(1rem, 1.5vw, 1.25rem);
    color: rgba(255,255,255,0.8);
    max-width: 52ch;
    line-height: 1.7;
    margin: 0 0 2.25rem;
  }
  .hero-cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 3rem;
  }
  .hero-usps {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255,255,255,0.15);
  }
  .hero-usp-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    color: rgba(255,255,255,0.8);
  }
  .usp-icon { font-size: 1.125rem; }

  @media (max-width: 900px) {
    .hero--split .container {
      grid-template-columns: 1fr;
    }
    .hero-image-wrap { order: -1; max-height: 280px; }
    .hero-img { height: 280px; }
  }
  @media (max-width: 640px) {
    .hero { padding: 3.5rem 0 3rem; }
    .hero-cta { flex-direction: column; }
    .hero-cta a { justify-content: center; }
  }
</style>
