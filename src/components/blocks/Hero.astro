---
// @cw/core – Hero.astro
// Zwei Varianten:
//   • hero.image gesetzt → Split-Layout (Text 55%, Bild 45%)
//   • kein hero.image → Gradient-Only (Text zentriert/links)
import { Image } from 'astro:assets';
import { siteData } from '@/data/site-data';

const hero = siteData.hero;
const hasImage = !!hero.image;
---
<section class:list={['hero', hasImage && 'hero--split']}>
  <div class="container">
    <div class="hero-content">
      <div class="hero-badge">
        <svg width="14" height="14" viewBox="0 0 512 512" aria-hidden="true">
          <polygon points="296,80 176,288 248,288 216,432 336,224 264,224" fill="currentColor"/>
        </svg>
        {hero.badge ?? 'Fertig in 7 Tagen – garantiert'}
      </div>

      <h1 set:html={hero.headline} />

      <p class="hero-sub">{hero.subtext}</p>

      <div class="hero-cta">
        <a href={hero.ctaPrimary?.href ?? '/kontakt'} class="btn-accent">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
          {hero.ctaPrimary?.label ?? 'Kostenlose Beratung anfragen'}
        </a>
        {hero.ctaSecondary && (
          <a href={hero.ctaSecondary.href} class="btn-outline">
            {hero.ctaSecondary.label}
          </a>
        )}
      </div>

      {siteData.usps?.length > 0 && (
        <div class="hero-usps">
          {siteData.usps.map((usp) => (
            <div class="hero-usp-item">
              <span class="usp-icon" aria-hidden="true">{usp.icon}</span>
              <span>{usp.title}</span>
            </div>
          ))}
        </div>
      )}
    </div>

    {hasImage && (
      <div class="hero-image-wrap">
        <Image
          src={hero.image!}
          alt={hero.imageAlt ?? siteData.name}
          width={600}
          height={450}
          loading="eager"
          format="webp"
          class="hero-img"
        />
      </div>
    )}
  </div>
</section>

<style>
  .hero {
    background: linear-gradient(135deg, var(--color-primary) 0%, #0f3460 100%);
    color: white;
    padding: 5rem 0 4rem;
  }

  /* Split-Layout (mit Bild) */
  .hero--split .container {
    display: grid;
    grid-template-columns: 55fr 45fr;
    gap: 3rem;
    align-items: center;
  }
  .hero-image-wrap {
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: 0 24px 64px rgba(0,0,0,0.35);
  }
  .hero-img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  /* Gemeinsame Styles */
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(255,107,53,0.2);
    color: var(--color-accent);
    border: 1px solid rgba(255,107,53,0.4);
    border-radius: 100px;
    padding: 0.375rem 0.875rem;
    font-size: 0.8125rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
    letter-spacing: 0.02em;
  }
  h1 {
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    color: white;
    margin: 0 0 1.25rem;
    max-width: 18ch;
  }
  .hero-sub {
    font-size: clamp(1rem, 1.5vw, 1.25rem);
    color: rgba(255,255,255,0.8);
    max-width: 52ch;
    line-height: 1.7;
    margin: 0 0 2.25rem;
  }
  .hero-cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 3rem;
  }
  .hero-usps {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255,255,255,0.15);
  }
  .hero-usp-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    color: rgba(255,255,255,0.8);
  }
  .usp-icon { font-size: 1.125rem; }

  @media (max-width: 900px) {
    .hero--split .container {
      grid-template-columns: 1fr;
    }
    .hero-image-wrap { order: -1; max-height: 280px; }
    .hero-img { height: 280px; }
  }
  @media (max-width: 640px) {
    .hero { padding: 3.5rem 0 3rem; }
    .hero-cta { flex-direction: column; }
    .hero-cta a { justify-content: center; }
  }
</style>
