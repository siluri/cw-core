---
/**
 * AEOSection — Answer Engine Optimization Q&A block.
 *
 * Renders heading/paragraph pairs in a narrow prose column.
 * No accordion, no Schema.org FAQPage markup — this is for
 * AI search engines (ChatGPT, Perplexity, Google AI Overviews)
 * that extract plain-text answers from visible page content.
 *
 * Use FAQ.astro for user-facing FAQ with accordion + Schema.org.
 * Use AEOSection for SEO/AEO-targeted Q&A without interactivity.
 *
 * @example
 *   <AEOSection items={[
 *     { q: 'Was ist Blitzsicht?', a: 'Blitzsicht ist...' },
 *     { q: 'Was kostet eine Website?', a: 'Ab 2.490 €...' },
 *   ]} />
 */
export interface AEOItem {
  /** Question (rendered as h2). */
  q: string;
  /** Answer (rendered as paragraph). */
  a: string;
}

interface Props {
  items?: readonly AEOItem[];
}

const { items = [] } = Astro.props;
---
{items.length > 0 && (
<section class="aeo-section">
  <div class="container aeo-container">
    {items.map((item) => (
      <>
        <h2>{item.q}</h2>
        <p>{item.a}</p>
      </>
    ))}
  </div>
</section>
)}

<style>
  .aeo-section {
    padding: var(--section-padding, 5rem) 0;
    background: white;
  }
  .aeo-container {
    max-width: 48rem;
    margin-inline: auto;
  }
  .aeo-container h2 {
    font-size: 1.25rem;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    color: var(--color-primary);
  }
  .aeo-container h2:first-child {
    margin-top: 0;
  }
  .aeo-container p {
    font-size: 1rem;
    line-height: 1.8;
    color: var(--color-muted);
    margin: 0;
  }
</style>
