---
/**
 * ReferenzenGrid — portfolio/reference project cards.
 *
 * Renders image+text cards in a stacked grid. Each card shows
 * an image (left) and description (right) on desktop, stacked
 * on mobile. Optional badge overlay on images (e.g. "Illustration").
 *
 * Images are passed as pre-resolved `ImageMetadata` or URL strings.
 *
 * @example
 *   <ReferenzenGrid items={[
 *     { title: 'Projekt A', description: '...', imageSrc: '/img/a.webp', imageAlt: '...' },
 *   ]} />
 */
export interface ReferenzItem {
  title: string;
  description: string;
  /** Image URL or path. */
  imageSrc: string;
  imageAlt: string;
  /** Optional badge text (e.g. "Illustration", "Foto"). */
  badge?: string;
}

interface Props {
  items?: readonly ReferenzItem[];
  /** Optional disclaimer shown below the grid. */
  disclaimer?: string;
}

const { items = [], disclaimer } = Astro.props;
---
{items.length > 0 && (
<section class="referenzen-section">
  <div class="container">
    <div class="referenzen-grid">
      {items.map((r) => (
        <article class="referenz-card">
          <div class="referenz-image-wrap">
            <img src={r.imageSrc} alt={r.imageAlt} loading="lazy" width="800" height="540" />
            {r.badge && <span class="referenz-badge">{r.badge}</span>}
          </div>
          <div class="referenz-body">
            <h2>{r.title}</h2>
            <p>{r.description}</p>
          </div>
        </article>
      ))}
    </div>

    {disclaimer && (
      <div class="referenzen-disclaimer">
        <p>{disclaimer}</p>
      </div>
    )}
  </div>
</section>
)}

<style>
  .referenzen-section {
    padding: 4rem 0;
  }
  .referenzen-grid {
    display: grid;
    gap: 2.5rem;
  }
  .referenz-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: center;
    background: var(--color-surface);
    border-radius: 0.75rem;
    overflow: hidden;
    border: 1px solid #e5e7eb;
  }
  @media (max-width: 768px) {
    .referenz-card { grid-template-columns: 1fr; }
  }
  .referenz-image-wrap {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: #f3f4f6;
  }
  .referenz-image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .referenz-badge {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: rgba(0, 0, 0, 0.7);
    color: white;
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .referenz-body {
    padding: 2rem;
  }
  .referenz-body h2 {
    font-size: 1.375rem;
    color: var(--color-primary);
    margin-bottom: 0.75rem;
  }
  .referenz-body p {
    line-height: 1.7;
    color: var(--color-muted, #374151);
  }
  .referenzen-disclaimer {
    padding: 2rem 0;
  }
  .referenzen-disclaimer p {
    max-width: 48rem;
    margin: 0 auto;
    padding: 1.5rem;
    background: white;
    border-left: 3px solid var(--color-primary);
    border-radius: 0 0.5rem 0.5rem 0;
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--color-muted, #4b5563);
  }
</style>
