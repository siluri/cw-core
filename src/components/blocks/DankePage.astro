---
/**
 * DankePage — full-screen "thank you" confirmation page.
 *
 * Used after form submissions. Renders a centered success message
 * with checkmark icon and back-to-home CTA. Uses CSS variables
 * for brand colors — no hardcoded hex values.
 *
 * Should be wrapped in BaseLayout with `robots="noindex"`.
 */
interface Props {
  heading?: string;
  message?: string;
  ctaLabel?: string;
  ctaHref?: string;
}

const {
  heading = 'Danke für Ihre Nachricht!',
  message = 'Wir melden uns innerhalb von 24 Stunden bei Ihnen.',
  ctaLabel = 'Zur Startseite',
  ctaHref = '/',
} = Astro.props;
---
<main class="danke-page">
  <div class="danke-content">
    <div class="danke-icon">
      <svg
        width="96"
        height="96"
        fill="none"
        stroke="var(--color-accent)"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        viewBox="0 0 24 24"
      >
        <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
      </svg>
    </div>

    <h1 class="danke-heading">{heading}</h1>
    <p class="danke-message">{message}</p>

    <a href={ctaHref} class="danke-cta">{ctaLabel}</a>
  </div>
</main>

<style>
  .danke-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-primary);
  }
  .danke-content {
    text-align: center;
    max-width: 28rem;
    margin: 0 auto;
    padding: 0 1rem;
  }
  .danke-icon {
    margin-bottom: 1.5rem;
  }
  .danke-heading {
    font-size: 1.875rem;
    font-weight: 700;
    color: white;
    margin-bottom: 1rem;
  }
  .danke-message {
    color: rgba(255, 255, 255, 0.65);
    margin-bottom: 2rem;
  }
  .danke-cta {
    display: inline-block;
    background: var(--color-accent);
    color: var(--color-accent-btn-text, white);
    font-weight: 500;
    padding: 0.75rem 1.5rem;
    border-radius: 0.5rem;
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .danke-cta:hover {
    opacity: 0.9;
  }
</style>

<script>
  import { track } from '../../utils/analytics/track';
  track('Thank You Page Viewed');
</script>
