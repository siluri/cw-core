---
// @cw/core – ContentPage.astro
// Legal/content pages: BaseLayout + Header + styled h1 + Footer
import BaseLayout from '@cw/core/layouts/BaseLayout.astro';
import Header from '@cw/core/components/layout/Header.astro';
import Footer from '@cw/core/components/layout/Footer.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---
<BaseLayout title={title} description={description}>
  <Header />
  <main class="content-page">
    <div class="container">
      <h1>{title}</h1>
      <slot />
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .content-page {
    padding: 4rem 0 6rem;
  }
  .content-page h1 {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid var(--color-surface);
  }
  .content-page :global(h2) { font-size: 1.375rem; margin: 2rem 0 0.75rem; }
  .content-page :global(h3) { font-size: 1.125rem; margin: 1.5rem 0 0.5rem; }
  .content-page :global(p) { margin-bottom: 1rem; line-height: 1.75; }
  .content-page :global(a) { color: var(--color-accent-text); }
  .content-page :global(ul), .content-page :global(ol) { padding-left: 1.5rem; margin-bottom: 1rem; }
  .content-page :global(li) { margin-bottom: 0.375rem; }
</style>
