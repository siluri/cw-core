---
// @cw/core – LeistungenSection.astro
// Zeigt siteData.leistungen als Card-Grid.
// Leer = Section wird nicht gerendert.
import { siteData } from '@/data/site-data';

const leistungen = siteData.leistungen ?? [];
---

{leistungen.length > 0 && (
  <section class="leistungen-section">
    <div class="container">
      <h2 class="section-heading">Unsere Leistungen</h2>
      <p class="section-subheading">{siteData.tagline}</p>
      <div class="leistungen-grid">
        {leistungen.map((item) => (
          <div class="leistung-card">
            {item.icon && <div class="leistung-icon" aria-hidden="true">{item.icon}</div>}
            <h3>{item.title}</h3>
            {item.description && <p>{item.description}</p>}
            {item.href && (
              <a href={item.href} class="leistung-link">
                Mehr erfahren
                <span aria-hidden="true"> →</span>
              </a>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>
)}

<style>
  .leistungen-section {
    padding: var(--section-padding, 5rem) 0;
    background: white;
  }

  .leistungen-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
    margin-top: 3rem;
  }

  .leistung-card {
    background: var(--color-surface);
    border-radius: 0.75rem;
    padding: 2rem;
    border: 1px solid #e5e7eb;
    transition: box-shadow 0.2s, transform 0.2s;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .leistung-card:hover {
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
    transform: translateY(-2px);
  }

  .leistung-icon {
    font-size: 2.25rem;
    line-height: 1;
    margin-bottom: 0.25rem;
  }

  .leistung-card h3 {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-primary);
    margin: 0;
  }

  .leistung-card p {
    font-size: 0.9rem;
    color: var(--color-muted);
    line-height: 1.6;
    margin: 0;
    flex: 1;
  }

  .leistung-link {
    display: inline-block;
    margin-top: 0.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-accent-text);
    text-decoration: none;
  }

  .leistung-link:hover {
    text-decoration: underline;
  }
</style>
