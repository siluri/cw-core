---
// @cw/core – StellenListe.astro
// Zeigt offene Stellen aus siteData.karriere.stellen
// Wenn leer: generischer Initiativbewerbung-Block
// JobPosting JSON-LD für Google for Jobs
import { siteData } from '@/data/site-data';

const karriere = siteData.karriere!;
const stellen = karriere.stellen ?? [];
const hasStellen = stellen.length > 0;
---
<section class="stellen-section" id="stellen">
  <div class="container">
    <div class="section-header">
      <h2 class="section-heading">
        {hasStellen ? 'Offene Stellen' : 'Initiativbewerbung'}
      </h2>
      <p class="section-subheading">
        {hasStellen
          ? `${stellen.length} offene Position${stellen.length !== 1 ? 'en' : ''} bei ${siteData.name}`
          : 'Keine passende Stelle dabei? Bewirb dich initiativ – wir freuen uns auf dich.'}
      </p>
    </div>

    {hasStellen ? (
      <>
        {/* JobPosting JSON-LD für Google for Jobs */}
        <script type="application/ld+json" set:html={JSON.stringify(
          stellen.map((stelle) => ({
            '@context': 'https://schema.org',
            '@type': 'JobPosting',
            title: stelle.titel,
            description: stelle.beschreibung,
            employmentType: stelle.typ === 'Vollzeit' ? 'FULL_TIME'
              : stelle.typ === 'Teilzeit' ? 'PART_TIME'
              : stelle.typ === 'Ausbildung' ? 'OTHER'
              : 'FULL_TIME',
            hiringOrganization: {
              '@type': 'Organization',
              name: siteData.name,
              sameAs: siteData.url,
            },
            jobLocation: {
              '@type': 'Place',
              address: {
                '@type': 'PostalAddress',
                addressLocality: siteData.legal.city,
                addressCountry: siteData.legal.country ?? 'DE',
              },
            },
            datePosted: new Date().toISOString().split('T')[0],
          }))
        )} />

        <div class="stellen-list">
          {stellen.map((stelle) => (
            <div class="stelle-card">
              <div class="stelle-header">
                <div>
                  <h3>{stelle.titel}</h3>
                  <span class="stelle-typ">{stelle.typ}</span>
                </div>
                <a href="#bewerbung" class="btn-accent stelle-cta">Jetzt bewerben</a>
              </div>
              {stelle.beschreibung && (
                <p class="stelle-beschreibung">{stelle.beschreibung}</p>
              )}
            </div>
          ))}
        </div>
      </>
    ) : (
      <div class="initiativ-box">
        <div class="initiativ-icon" aria-hidden="true">📬</div>
        <p>
          Schick uns einfach deine Bewerbungsunterlagen an{' '}
          <a href={`mailto:${karriere.kontaktEmail ?? siteData.contact.email}`}>
            {karriere.kontaktEmail ?? siteData.contact.email}
          </a>{' '}
          – oder nutze das Formular unten.
        </p>
        <a href="#bewerbung" class="btn-accent">Initiativ bewerben</a>
      </div>
    )}
  </div>
</section>

<style>
  .stellen-section { padding: 5rem 0; background: white; }
  .section-header { text-align: center; margin-bottom: 3rem; }

  .stellen-list { display: flex; flex-direction: column; gap: 1rem; max-width: 56rem; margin-inline: auto; }
  .stelle-card {
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 0.75rem;
    padding: 1.5rem 2rem;
    transition: box-shadow 0.2s, border-color 0.2s;
  }
  .stelle-card:hover { box-shadow: 0 4px 20px rgba(0,0,0,0.08); border-color: var(--color-accent); }
  .stelle-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .stelle-header h3 { font-size: 1.125rem; margin: 0 0 0.375rem; }
  .stelle-typ {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    background: var(--color-surface);
    color: var(--color-muted);
    padding: 0.2rem 0.625rem;
    border-radius: 100px;
  }
  .stelle-cta { padding: 0.5rem 1.25rem; font-size: 0.875rem; flex-shrink: 0; }
  .stelle-beschreibung { margin: 1rem 0 0; font-size: 0.9375rem; color: var(--color-muted); line-height: 1.65; }

  /* Initiativbewerbung */
  .initiativ-box {
    max-width: 36rem;
    margin-inline: auto;
    text-align: center;
    background: var(--color-surface);
    border-radius: 1rem;
    padding: 3rem 2rem;
    border: 2px dashed #e5e7eb;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }
  .initiativ-icon { font-size: 2.5rem; }
  .initiativ-box p { font-size: 1rem; color: var(--color-muted); line-height: 1.7; margin: 0; }
  .initiativ-box a:not(.btn-accent) { color: var(--color-accent-text); font-weight: 600; }
</style>
