---
// @cw/core – BewerbungsForm.astro
// Tally-Embed für Bewerbungen + Fallback-Kontakt wenn kein Tally konfiguriert
import TallyEmbed from '@cw/core/components/forms/TallyEmbed.astro';
import { siteData } from '@/data/site-data';

const karriere = siteData.karriere!;
const hasTally = !!karriere.tallyFormId;
const kontaktEmail = karriere.kontaktEmail ?? siteData.contact.email;
---
<section class="bewerbung-section" id="bewerbung">
  <div class="container">
    <div class="section-header">
      <h2 class="section-heading">Jetzt bewerben</h2>
      <p class="section-subheading">
        Wir melden uns innerhalb von 48 Stunden bei dir.
      </p>
    </div>

    {hasTally ? (
      <div class="form-wrap">
        <TallyEmbed
          formId={karriere.tallyFormId!}
          fallbackEmail={kontaktEmail}
        />
      </div>
    ) : (
      <div class="email-fallback">
        <p>
          Sende deine Bewerbungsunterlagen (Anschreiben, Lebenslauf, Zeugnisse) per E-Mail an:
        </p>
        <a href={`mailto:${kontaktEmail}?subject=Bewerbung bei ${siteData.name}`} class="btn-accent">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
          {kontaktEmail}
        </a>
        <p class="hint">Bitte nenne in der Betreffzeile die gewünschte Stelle oder "Initiativbewerbung".</p>
      </div>
    )}
  </div>
</section>

<style>
  .bewerbung-section { padding: 5rem 0; background: var(--color-surface); }
  .section-header { text-align: center; margin-bottom: 3rem; }
  .form-wrap { max-width: 48rem; margin-inline: auto; }

  .email-fallback {
    max-width: 32rem;
    margin-inline: auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }
  .email-fallback p { font-size: 1rem; color: var(--color-muted); line-height: 1.7; margin: 0; }
  .email-fallback .hint { font-size: 0.875rem; }
</style>
