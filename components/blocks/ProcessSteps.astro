---
// @cw/core – ProcessSteps.astro
// Inhalte kommen aus siteData.processSteps (nicht mehr hardcoded)
import { siteData } from '@/data/site-data';
const steps = siteData.processSteps ?? [];
---
{steps.length > 0 && (
<section class="process-section">
  <div class="container">
    <div class="section-header">
      <h2 class="section-heading">So funktioniert's</h2>
      <p class="section-subheading">Von Erstgespräch bis Live-Gang in {steps.length} einfachen Schritten.</p>
    </div>

    <div class="steps">
      {steps.map((step) => (
        <div class="step">
          <div class="step-nr" aria-hidden="true">{step.nr}</div>
          <div class="step-body">
            <div class="step-icon" aria-hidden="true">{step.icon}</div>
            <h3>{step.title}</h3>
            <p>{step.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
)}

<style>
  .process-section { padding: 5rem 0; background: white; }
  .section-header { text-align: center; margin-bottom: 3.5rem; }
  .steps {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
  }
  .step { position: relative; }
  .step-nr {
    font-size: 3rem;
    font-weight: 800;
    color: var(--color-accent);
    opacity: 0.15;
    line-height: 1;
    margin-bottom: 0.5rem;
  }
  .step-body {
    background: var(--color-surface);
    border-radius: 0.75rem;
    padding: 1.5rem;
    height: 100%;
  }
  .step-icon { font-size: 1.75rem; margin-bottom: 0.75rem; display: block; }
  .step-body h3 { font-size: 1.0625rem; margin-bottom: 0.5rem; }
  .step-body p { font-size: 0.9rem; color: var(--color-muted); line-height: 1.65; margin: 0; }

  @media (max-width: 500px) {
    .steps { grid-template-columns: 1fr; }
  }
</style>
