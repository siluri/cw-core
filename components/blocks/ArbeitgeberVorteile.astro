---
// @cw/core – ArbeitgeberVorteile.astro
// Benefits-Grid für Karriere-Seite
import { siteData } from '@/data/site-data';
const benefits = siteData.karriere?.benefits ?? [];
---
{benefits.length > 0 && (
<section class="vorteile-section">
  <div class="container">
    <div class="section-header">
      <h2 class="section-heading">Was wir bieten</h2>
      <p class="section-subheading">Warum {siteData.name} ein guter Arbeitgeber ist.</p>
    </div>

    <div class="vorteile-grid">
      {benefits.map((benefit) => (
        <div class="vorteil-card">
          <div class="vorteil-icon" aria-hidden="true">{benefit.icon}</div>
          <h3>{benefit.title}</h3>
          <p>{benefit.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
)}

<style>
  .vorteile-section { padding: 5rem 0; background: var(--color-surface); }
  .section-header { text-align: center; margin-bottom: 3rem; }
  .vorteile-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.5rem;
  }
  .vorteil-card {
    background: white;
    border-radius: 0.75rem;
    padding: 1.75rem;
    border: 1px solid #e5e7eb;
    transition: box-shadow 0.2s, transform 0.2s;
  }
  .vorteil-card:hover {
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
    transform: translateY(-2px);
  }
  .vorteil-icon { font-size: 2rem; margin-bottom: 0.875rem; display: block; }
  .vorteil-card h3 { font-size: 1rem; margin-bottom: 0.5rem; color: var(--color-primary); }
  .vorteil-card p { font-size: 0.9rem; color: var(--color-muted); line-height: 1.6; margin: 0; }
</style>
