---
// @cw/core – Footer.astro
// Karriere-Link wird angezeigt wenn siteData.karriere?.enabled !== false
import { siteData } from '@/data/site-data';
const year = new Date().getFullYear();
const karriereEnabled = siteData.karriere?.enabled !== false;
---
<footer>
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="logo-img">
          <img src="/logo.svg" alt={siteData.name} loading="lazy" />
        </a>
        <a href="/" class="logo-name">
          {siteData.name}
        </a>
        <p>{siteData.description}</p>
        <a href={`mailto:${siteData.contact.email}`} class="contact-link">
          {siteData.contact.email}
        </a>
        {siteData.contact.phone && (
          <a href={`tel:${siteData.contact.phone}`} class="contact-link">
            {siteData.contact.phone}
          </a>
        )}
      </div>

      <div class="footer-links">
        <h3>Leistungen</h3>
        <ul>
          {(siteData.nav?.footer?.leistungen ?? []).map((item) => (
            <li><a href={item.href}>{item.label}</a></li>
          ))}
          {karriereEnabled && <li><a href="/karriere">Karriere</a></li>}
        </ul>
      </div>

      <div class="footer-links">
        <h3>Rechtliches</h3>
        <ul>
          {(siteData.nav?.footer?.rechtliches ?? [
            { label: 'Impressum', href: '/impressum' },
            { label: 'Datenschutz', href: '/datenschutz' },
          ]).map((item) => (
            <li><a href={item.href}>{item.label}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p>© {year} {siteData.legal.owner} · {siteData.legal.form ?? 'Einzelunternehmen'} · {siteData.legal.city}</p>
      <p class="footer-tagline">{siteData.tagline}</p>
    </div>
  </div>
</footer>

<style>
  footer {
    background: var(--color-primary);
    color: rgba(255,255,255,0.75);
    padding-top: 3.5rem;
    padding-bottom: 1.5rem;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 3rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }
  .logo-img {
    display: block;
    margin-bottom: 1rem;
  }
  .logo-img img {
    display: block;
    width: auto;
    height: auto;
    max-width: 200px;
    max-height: 80px;
  }
  .logo-name {
    display: block;
    font-weight: 700;
    font-size: 1.125rem;
    color: white;
    text-decoration: none;
    margin-bottom: 0.875rem;
  }
  .footer-brand p {
    font-size: 0.9rem;
    line-height: 1.7;
    max-width: 28ch;
  }
  .contact-link {
    display: inline-block;
    margin-top: 0.5rem;
    color: var(--color-accent);
    text-decoration: none;
    font-size: 0.9rem;
  }
  .contact-link:hover { text-decoration: underline; }
  .footer-links h3 {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.5);
    margin-bottom: 1rem;
  }
  .footer-links ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.625rem; }
  .footer-links a {
    color: rgba(255,255,255,0.75);
    text-decoration: none;
    font-size: 0.9375rem;
    transition: color 0.15s;
  }
  .footer-links a:hover { color: white; }
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 1.5rem;
    font-size: 0.8125rem;
    color: rgba(255,255,255,0.4);
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .footer-tagline { font-style: italic; }

  @media (max-width: 767px) {
    .footer-grid { grid-template-columns: 1fr; gap: 2rem; }
    .footer-bottom { flex-direction: column; align-items: flex-start; }
  }
</style>
