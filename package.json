{
  "name": "@cw/core",
  "version": "0.8.26-alpha",
  "type": "module",
  "description": "Shared Astro components, layouts and styles for Blitzsicht customer websites",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./layouts/*": "./src/layouts/*",
    "./components/*": "./src/components/*",
    "./styles/*": "./src/styles/*",
    "./templates/*": "./src/templates/*",
    "./utils/forms/handle-submission": "./src/utils/forms/handle-submission.js",
    "./utils/*": "./src/utils/*.ts",
    "./types/*": "./src/types/*",
    "./scripts/*": "./scripts/*",
    "./api/*": "./src/api/*.js"
  },
  "scripts": {
    "build": "echo '@cw/core is a source-only Astro component library — no build step (consumers compile via their own Astro pipeline).'",
    "check": "astro check",
    "optimize:images": "node scripts/optimize-images.mjs --delete-originals",
    "generate:og": "node scripts/generate-og.mjs",
    "lint:css": "stylelint 'src/**/*.{astro,css}'"
  },
  "peerDependencies": {
    "astro": ">=5.0.0",
    "lenis": ">=1.1.0",
    "tailwindcss": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "lenis": {
      "optional": true
    }
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.0",
    "astro": "^5.0.0",
    "lenis": "^1.3.23",
    "postcss-html": "^1.8.0",
    "schema-dts": "^2.0.0",
    "simple-git-hooks": "^2.11.0",
    "stylelint": "^16.0.0",
    "stylelint-config-standard": "^36.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.4.0"
  },
  "keywords": [
    "astro",
    "components",
    "customer-websites",
    "blitzsicht"
  ],
  "license": "UNLICENSED",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/siluri/cw-core.git",
    "directory": "packages/@cw/core"
  }
}
