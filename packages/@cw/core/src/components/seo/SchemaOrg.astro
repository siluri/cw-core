---
// @cw/core – SchemaOrg.astro
// LocalBusiness + WebSite JSON-LD from siteData
import type { WithContext, LocalBusiness, WebSite } from 'schema-dts';
import { siteData } from '@/data/site-data';

interface Props {
  priceRange?: string;
  sameAs?: string[];
}
const { priceRange = '€€', sameAs = [] } = Astro.props;

const localBusinessSchema: WithContext<LocalBusiness> = {
  '@context': 'https://schema.org',
  '@type': ['LocalBusiness', 'ProfessionalService'],
  name: siteData.name,
  description: siteData.description,
  url: siteData.url,
  logo: `${siteData.url}/logo.png`,
  image: new URL(siteData.seo.ogImage, siteData.url).toString(),
  address: {
    '@type': 'PostalAddress',
    streetAddress: siteData.legal.street,
    postalCode: siteData.legal.zip,
    addressLocality: siteData.legal.city,
    addressCountry: siteData.legal.country,
  },
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'customer service',
    email: siteData.contact.email,
    ...(siteData.contact.phone ? { telephone: siteData.contact.phone } : {}),
    availableLanguage: ['German'],
  },
  areaServed: 'DE',
  priceRange,
  sameAs,
};

const webSiteSchema: WithContext<WebSite> = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: siteData.name,
  description: siteData.description,
  url: siteData.url,
};
---
<script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(webSiteSchema)} />
