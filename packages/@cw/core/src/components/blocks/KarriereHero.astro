---
// @cw/core – KarriereHero.astro
import { Image } from 'astro:assets';
import { siteData } from '@/data/site-data';

const karriere = siteData.karriere!;
const headline = karriere.headline ?? `Karriere bei ${siteData.name}`;
const subtext = karriere.subtext ?? `Wir suchen Verstärkung. Werde Teil unseres Teams.`;
const teamImage = siteData.images?.aboutTeam;
---
<section class="karriere-hero">
  <div class="container">
    <div class:list={['hero-content', teamImage && 'hero-content--split']}>
      <div class="hero-text">
        <div class="hero-badge">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
            <circle cx="9" cy="7" r="4"/>
            <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
          </svg>
          Wir stellen ein
        </div>
        <h1>{headline}</h1>
        <p class="hero-sub">{subtext}</p>
        <a href="#stellen" class="btn-accent">Offene Stellen ansehen</a>
      </div>

      {teamImage && (
        <div class="hero-image-wrap">
          <Image
            src={teamImage}
            alt={`Team ${siteData.name}`}
            width={560}
            height={400}
            loading="eager"
            format="webp"
            class="hero-img"
          />
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .karriere-hero {
    background: linear-gradient(135deg, var(--color-primary) 0%, #0f3460 100%);
    color: white;
    padding: 5rem 0 4rem;
  }
  .hero-content--split {
    display: grid;
    grid-template-columns: 55fr 45fr;
    gap: 3rem;
    align-items: center;
  }
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(255,255,255,0.1);
    color: rgba(255,255,255,0.9);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 100px;
    padding: 0.375rem 0.875rem;
    font-size: 0.8125rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
    letter-spacing: 0.02em;
  }
  h1 {
    font-size: clamp(2rem, 4vw, 3.25rem);
    color: white;
    margin: 0 0 1.25rem;
    max-width: 20ch;
  }
  .hero-sub {
    font-size: clamp(1rem, 1.5vw, 1.2rem);
    color: rgba(255,255,255,0.8);
    max-width: 52ch;
    line-height: 1.7;
    margin: 0 0 2rem;
  }
  .hero-image-wrap {
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: 0 24px 64px rgba(0,0,0,0.35);
  }
  .hero-img { display: block; width: 100%; height: auto; object-fit: cover; }

  @media (max-width: 900px) {
    .hero-content--split { grid-template-columns: 1fr; }
    .hero-image-wrap { order: -1; max-height: 250px; }
    .hero-img { height: 250px; }
  }
</style>
