---
// @cw/core – USPSection.astro
import { siteData } from '@/data/site-data';
---
<section class="usp-section">
  <div class="container">
    <div class="usp-grid">
      {siteData.usps.map((usp) => (
        <div class="usp-card">
          <div class="usp-icon" aria-hidden="true">{usp.icon}</div>
          <h3>{usp.title}</h3>
          <p>{usp.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .usp-section { padding: 5rem 0; background: var(--color-surface); }
  .usp-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.5rem;
  }
  .usp-card {
    background: white;
    border-radius: 0.75rem;
    padding: 1.75rem;
    border: 1px solid #e5e7eb;
    transition: box-shadow 0.2s, transform 0.2s;
  }
  .usp-card:hover {
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
    transform: translateY(-2px);
  }
  .usp-icon { font-size: 2rem; margin-bottom: 0.875rem; display: block; }
  .usp-card h3 { font-size: 1rem; margin-bottom: 0.5rem; color: var(--color-primary); }
  .usp-card p { font-size: 0.9rem; color: var(--color-muted); line-height: 1.6; margin: 0; }
</style>
