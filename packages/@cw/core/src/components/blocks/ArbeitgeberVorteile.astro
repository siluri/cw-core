---
/**
 * @cw/core – ArbeitgeberVorteile.astro
 *
 * Benefits-Grid für Karriere-Seite. Prop-driven: no `@/data/site-data`
 * import.
 *
 * @example
 *   <ArbeitgeberVorteile
 *     items={siteData.karriere?.benefits ?? []}
 *     siteName={siteData.name}
 *   />
 */
export interface BenefitItem {
  /** Emoji or short string used as icon. */
  icon: string;
  /** Benefit title. */
  title: string;
  /** Benefit description. */
  description: string;
}

interface Props {
  /** Benefit cards. Section is omitted entirely if empty. */
  items?: BenefitItem[];
  /** Site/employer name (interpolated into subheading). */
  siteName?: string;
  /** Optional override for the section heading. */
  heading?: string;
  /** Optional override for the section subheading. `{siteName}` is replaced. */
  subheadingTemplate?: string;
}

const {
  items = [],
  siteName = '',
  heading = 'Was wir bieten',
  subheadingTemplate = 'Warum {siteName} ein guter Arbeitgeber ist.',
} = Astro.props;

const subheading = subheadingTemplate.replace('{siteName}', siteName);
---
{items.length > 0 && (
<section class="vorteile-section">
  <div class="container">
    <div class="section-header">
      <h2 class="section-heading">{heading}</h2>
      <p class="section-subheading">{subheading}</p>
    </div>

    <div class="vorteile-grid">
      {items.map((benefit) => (
        <div class="vorteil-card">
          <div class="vorteil-icon" aria-hidden="true">{benefit.icon}</div>
          <h3>{benefit.title}</h3>
          <p>{benefit.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
)}

<style>
  .vorteile-section { padding: 5rem 0; background: var(--color-surface); }
  .section-header { text-align: center; margin-bottom: 3rem; }
  .vorteile-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.5rem;
  }
  .vorteil-card {
    background: white;
    border-radius: 0.75rem;
    padding: 1.75rem;
    border: 1px solid #e5e7eb;
    transition: box-shadow 0.2s, transform 0.2s;
  }
  .vorteil-card:hover {
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
    transform: translateY(-2px);
  }
  .vorteil-icon { font-size: 2rem; margin-bottom: 0.875rem; display: block; }
  .vorteil-card h3 { font-size: 1rem; margin-bottom: 0.5rem; color: var(--color-primary); }
  .vorteil-card p { font-size: 0.9rem; color: var(--color-muted); line-height: 1.6; margin: 0; }
</style>
