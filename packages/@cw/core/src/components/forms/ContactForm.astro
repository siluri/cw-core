---
// @cw/core – ContactForm.astro
// Natives HTML-Form — kein iframe, DSGVO-konform
// Primär: AJAX + Inline-Erfolgsmeldung | Fallback (kein JS): native POST
// actionUrl: wenn gesetzt, direkt POST an eigenen Endpoint statt Web3Forms
import { siteData } from '@/data/site-data';

interface Props {
  formKey?: string;
  subject?: string;
  formType?: 'contact' | 'audit' | 'bewerbung';
  fallbackEmail?: string;
  actionUrl?: string;
}

const {
  formKey = '',
  subject = `Neue Anfrage – ${siteData.name}`,
  formType = 'contact',
  fallbackEmail = siteData.contact.email,
  actionUrl,
} = Astro.props;

const useWeb3Forms = !actionUrl;
const hasKey = useWeb3Forms ? (!!formKey && !formKey.startsWith('TODO')) : true;
const submitUrl = actionUrl ?? 'https://api.web3forms.com/submit';
---

{hasKey ? (
  <div class="contact-form-wrap">
    <form
      class="contact-form"
      action={submitUrl}
      method="POST"
      data-web3form
      data-submit-url={submitUrl}
    >
      {useWeb3Forms && (
        <>
          <input type="hidden" name="access_key" value={formKey} />
          <input type="hidden" name="subject" value={subject} />
          <input type="hidden" name="from_name" value={siteData.name} />
          <!-- Honeypot Spam-Schutz -->
          <input type="checkbox" name="botcheck" style="display:none" tabindex="-1" autocomplete="off" />
        </>
      )}

      {formType === 'contact' && (
        <>
          <div class="form-row">
            <label for="cf-name">Ihr Name <span aria-hidden="true">*</span></label>
            <input type="text" id="cf-name" name="name" required autocomplete="name" />
          </div>
          <div class="form-row">
            <label for="cf-email">E-Mail <span aria-hidden="true">*</span></label>
            <input type="email" id="cf-email" name="email" required autocomplete="email" />
          </div>
          <div class="form-row">
            <label for="cf-company">Unternehmen <span class="optional">(optional)</span></label>
            <input type="text" id="cf-company" name="company" autocomplete="organization" />
          </div>
          <div class="form-row">
            <label for="cf-message">Nachricht <span aria-hidden="true">*</span></label>
            <textarea id="cf-message" name="message" rows="4" required></textarea>
          </div>
        </>
      )}

      {formType === 'audit' && (
        <>
          <div class="form-row">
            <label for="cf-email">Ihre E-Mail <span aria-hidden="true">*</span></label>
            <input type="email" id="cf-email" name="email" required autocomplete="email" />
          </div>
          <div class="form-row">
            <label for="cf-url">Ihre Website-URL <span aria-hidden="true">*</span></label>
            <input type="url" id="cf-url" name="website" required placeholder="https://ihre-website.de" />
          </div>
          <div class="form-row">
            <label for="cf-name">Ihr Name <span class="optional">(optional)</span></label>
            <input type="text" id="cf-name" name="name" autocomplete="name" />
          </div>
        </>
      )}

      {formType === 'bewerbung' && (
        <>
          <div class="form-row">
            <label for="cf-name">Ihr Name <span aria-hidden="true">*</span></label>
            <input type="text" id="cf-name" name="name" required autocomplete="name" />
          </div>
          <div class="form-row">
            <label for="cf-email">E-Mail <span aria-hidden="true">*</span></label>
            <input type="email" id="cf-email" name="email" required autocomplete="email" />
          </div>
          <div class="form-row">
            <label for="cf-phone">Telefon <span class="optional">(optional)</span></label>
            <input type="tel" id="cf-phone" name="phone" autocomplete="tel" />
          </div>
          <div class="form-row">
            <label for="cf-message">Anschreiben <span aria-hidden="true">*</span></label>
            <textarea id="cf-message" name="message" rows="5" required
              placeholder="Bitte nenne die gewünschte Stelle oder schreibe &#34;Initiativbewerbung&#34;."></textarea>
          </div>
        </>
      )}

      <div class="form-submit">
        <button type="submit" class="btn-accent">
          <span class="btn-label">Absenden</span>
          <span class="btn-loading" aria-hidden="true" hidden>
            <span class="spinner" aria-hidden="true"></span>
            Wird gesendet…
          </span>
        </button>
      </div>
    </form>

    <div class="form-success" hidden>
      <div class="success-icon" aria-hidden="true">✓</div>
      <h3>Vielen Dank!</h3>
      {formType === 'audit' && <p>Wir analysieren Ihre Website und melden uns innerhalb von 48 Stunden.</p>}
      {formType === 'bewerbung' && <p>Wir haben Ihre Bewerbung erhalten und melden uns innerhalb von 48 Stunden.</p>}
      {formType === 'contact' && <p>Wir melden uns innerhalb von 24 Stunden bei Ihnen.</p>}
    </div>

    <div class="form-error" hidden>
      <p>
        Etwas ist schiefgelaufen. Bitte schreiben Sie uns direkt an
        <a href={`mailto:${fallbackEmail}`}>{fallbackEmail}</a>.
      </p>
    </div>
  </div>
) : (
  <div class="form-email-fallback">
    <p>Kontaktieren Sie uns direkt per E-Mail:</p>
    <a href={`mailto:${fallbackEmail}`} class="btn-accent">{fallbackEmail}</a>
  </div>
)}

<script>
  document.querySelectorAll('form[data-web3form]').forEach((formEl) => {
    const form = formEl as HTMLFormElement;
    const wrap = form.closest('.contact-form-wrap') as HTMLElement | null;
    if (!wrap) return;

    const success = wrap.querySelector('.form-success') as HTMLElement | null;
    const error = wrap.querySelector('.form-error') as HTMLElement | null;
    const btnLabel = form.querySelector('.btn-label') as HTMLElement | null;
    const btnLoading = form.querySelector('.btn-loading') as HTMLElement | null;
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (btn) btn.disabled = true;
      if (btnLabel) btnLabel.hidden = true;
      if (btnLoading) btnLoading.hidden = false;
      if (error) error.hidden = true;
      form.dataset.submitting = 'true';

      try {
        const data = new FormData(form);
        const submitUrl = form.dataset.submitUrl ?? 'https://api.web3forms.com/submit';
        const isCustomEndpoint = !!form.dataset.submitUrl && !submitUrl.includes('web3forms.com');

        let res: Response;
        if (isCustomEndpoint) {
          // Eigener Endpoint: JSON senden (Vercel parst multipart/form-data nicht automatisch)
          const obj: Record<string, string> = {};
          data.forEach((v, k) => { if (typeof v === 'string') obj[k] = v; });
          res = await fetch(submitUrl, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(obj),
          });
        } else {
          res = await fetch(submitUrl, { method: 'POST', body: data });
        }

        const json = await res.json() as { success?: boolean; ok?: boolean; message?: string };
        if (json.success || json.ok) {
          (form as HTMLElement).hidden = true;
          if (success) success.hidden = false;
        } else {
          throw new Error(json.message ?? 'Unknown error');
        }
      } catch {
        if (btn) { btn.disabled = false; }
        if (btnLabel) btnLabel.hidden = false;
        if (btnLoading) btnLoading.hidden = true;
        if (error) error.hidden = false;
        delete form.dataset.submitting;
      }
    });
  });
</script>

<style>
  .contact-form-wrap { width: 100%; }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .form-row {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .contact-form label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-primary);
  }

  .contact-form .optional {
    font-weight: 400;
    color: var(--color-muted);
    font-size: 0.8125rem;
  }

  .contact-form input,
  .contact-form textarea {
    padding: 0.625rem 0.875rem;
    border: 1px solid #d1d5db;
    border-radius: 0.375rem;
    font-size: 0.9375rem;
    font-family: inherit;
    width: 100%;
    box-sizing: border-box;
    background: #fff;
  }

  .contact-form input:focus,
  .contact-form textarea:focus {
    outline: 2px solid var(--color-accent);
    outline-offset: 1px;
    border-color: transparent;
  }

  .contact-form textarea { resize: vertical; }

  .form-submit { margin-top: 0.5rem; }

  /* Spinner */
  .spinner {
    display: inline-block;
    width: 1em;
    height: 1em;
    border: 2px solid rgba(255,255,255,0.4);
    border-top-color: white;
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
    vertical-align: middle;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* Form ausgegraut während Submit */
  .contact-form[data-submitting] input,
  .contact-form[data-submitting] textarea,
  .contact-form[data-submitting] select {
    opacity: 0.5;
    pointer-events: none;
  }

  /* Erfolg */
  .form-success {
    text-align: center;
    padding: 2.5rem 1rem;
  }
  .success-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.5rem;
    height: 3.5rem;
    background: #dcfce7;
    color: #16a34a;
    border-radius: 50%;
    font-size: 1.75rem;
    margin-bottom: 1.25rem;
  }
  .form-success h3 { font-size: 1.25rem; margin-bottom: 0.5rem; color: var(--color-primary); }
  .form-success p { color: var(--color-muted); margin: 0; }

  /* Fehler */
  .form-error {
    margin-top: 0.75rem;
    padding: 0.875rem 1rem;
    background: #fef2f2;
    border: 1px solid #fca5a5;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    color: #991b1b;
  }
  .form-error p { margin: 0; }
  .form-error a { color: #991b1b; font-weight: 600; }

  /* Kein-Key-Fallback */
  .form-email-fallback {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
  }
  .form-email-fallback p { color: var(--color-muted); margin: 0; }
</style>
