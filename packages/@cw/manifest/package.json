{
  "name": "@cw/manifest",
  "version": "0.1.0-alpha",
  "type": "module",
  "description": "Zod schema and TypeScript types for the Blitzsicht customer-website SiteManifest (SSOT).",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts",
    "./types": "./src/types.ts"
  },
  "scripts": {
    "build": "echo '@cw/manifest is source-only — consumers compile via their own TS/Astro pipeline.'",
    "check": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "zod": "^3.23.0",
    "typescript": "^5.4.0",
    "vitest": "^2.1.0"
  },
  "keywords": ["manifest", "schema", "zod", "customer-websites", "blitzsicht"],
  "license": "UNLICENSED",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/siluri/cw-core.git",
    "directory": "packages/@cw/manifest"
  }
}
